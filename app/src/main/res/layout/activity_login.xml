<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="28dp">

        <ImageView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/app_logo"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MI Trade Analyzer"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="License key se activate karein"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="32dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔑 License Key"
                android:textColor="@color/accent_light"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etLicenseKey"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:hint="MITA-XXXX-XXXX-XXXX"
                android:textColorHint="#5B6B85"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:background="@drawable/input_bg"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:inputType="textCapCharacters"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btnActivate"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="✅ Activate Karein"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:background="@drawable/button_primary_bg" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvLoginStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/danger"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="16dp" />

        <ProgressBar
            android:id="@+id/loginProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="License key nahi hai? WhatsApp karein: 0306-2015326"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginTop="28dp" />

    </LinearLayout>
</ScrollView>
